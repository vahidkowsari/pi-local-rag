{
  "name": "pi-local-rag",
  "version": "0.4.1",
  "description": "Local hybrid RAG pipeline for the Pi coding agent. SQLite FTS5 + sqlite-vec, ONNX embeddings via Transformers.js, PDF/DOCX/HTML extraction (with OCR fallback), per-project storage, auto-injection. Zero cloud dependency.",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "index.ts",
    "constants.ts",
    "store.ts",
    "config.ts",
    "db.ts",
    "chunking.ts",
    "embed.ts",
    "search.ts",
    "indexing.ts",
    "types/**/*.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npx --yes -p typescript@5.7.3 tsc -p tsconfig.json --noCheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-coding-agent",
    "rag",
    "search",
    "bm25",
    "vector",
    "embeddings",
    "hybrid-search",
    "index",
    "local",
    "offline",
    "transformers",
    "sqlite",
    "fts5",
    "sqlite-vec",
    "pdf",
    "docx",
    "ocr"
  ],
  "author": "kowsari",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vahidkowsari/pi-local-rag.git"
  },
  "homepage": "https://github.com/vahidkowsari/pi-local-rag#readme",
  "bugs": {
    "url": "https://github.com/vahidkowsari/pi-local-rag/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.10.0",
    "ignore": "^7.0.5",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "sqlite-vec": "^0.1.9",
    "turndown": "^7.2.4"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.60.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^4.1.7",
    "jszip": "^3.10.1",
    "vitest": "^4.1.7"
  }
}
