{
  "name": "pi-local-rag",
  "version": "0.3.0",
  "description": "Hybrid RAG pipeline for the Pi coding agent. BM25 + local vector embeddings (Transformers.js) + auto-injection into LLM context. Zero cloud dependency.",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "index.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npx --yes -p typescript@5.7.3 tsc -p tsconfig.json --noCheck"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-coding-agent",
    "rag",
    "search",
    "bm25",
    "vector",
    "embeddings",
    "hybrid-search",
    "index",
    "local",
    "offline",
    "transformers"
  ],
  "author": "kowsari",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vahidkowsari/pi-local-rag.git"
  },
  "homepage": "https://github.com/vahidkowsari/pi-local-rag#readme",
  "bugs": {
    "url": "https://github.com/vahidkowsari/pi-local-rag/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.60.0"
  }
}
